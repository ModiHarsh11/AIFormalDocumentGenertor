# =============================================================
# Environment variables for BISAG-N FormalDocument Generator
# Copy this file to .env and fill in the values.
# =============================================================

# --- Django ---
# Generate a unique one for production:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Which settings module to use:
#   ai_formal_generator.settings.development  (default)
#   ai_formal_generator.settings.production
DJANGO_SETTINGS_MODULE=ai_formal_generator.settings.development

# --- AI / LLM ---
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash-lite

# --- Email (password reset) ---
# Development defaults to console backend in settings/development.py.
# For SMTP-based delivery (typically production), configure these values:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DEFAULT_FROM_EMAIL=no-reply@example.com
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

# --- Production only ---
# DEBUG=False
# ALLOWED_HOSTS=example.com,www.example.com
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=bisag_formal
# DB_USER=bisag
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# MEDIA_ROOT=/var/www/bisag/media
